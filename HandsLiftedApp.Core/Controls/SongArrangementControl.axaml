<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="220"
             xmlns:vme="using:HandsLiftedApp.ViewModels.Editor"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:converters="using:HandsLiftedApp.Converters"
             xmlns:items="clr-namespace:HandsLiftedApp.Core.Models.RuntimeData.Items"
             xmlns:behaviours="clr-namespace:HandsLiftedApp.Controls.Behaviours;assembly=HandsLiftedApp.Controls"
             xmlns:controls="clr-namespace:HandsLiftedApp.Controls"
             x:Name="root"
             x:DataType="items:SongItemInstance"
             x:Class="HandsLiftedApp.Controls.SongArrangementControl">

    <Design.DataContext>
        <vme:ExampleSongItemInstance />
    </Design.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>

            <converters:StanzaSortConverter x:Key="StanzaSortConverter" />

            <Flyout Placement="BottomEdgeAlignedLeft" x:Key="MySharedFlyout">
                <ItemsControl ItemsSource="{Binding Stanzas, Converter={StaticResource StanzaSortConverter}}"
                              MinHeight="20" Margin="4" VerticalAlignment="Center" MinWidth="150">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Background="{Binding Colour}"
                                    Foreground="Black"
                                    Click="OnAddPartClick"
                                    ToolTip.Placement="Right"
                                    ToolTip.ShowDelay="0" ToolTip.Tip="{Binding Lyrics}">
                                <Button.Styles>
                                    <Style Selector="ToolTip">
                                        <Setter Property="IsHitTestVisible" Value="False" />
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundText}" />
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Flyout>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ForegroundText">White</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ForegroundText">White</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="MenuItem">
            <!-- <Setter Property="Foreground" Value="Red" /> -->
            <Setter Property="FontSize" Value="11" />
        </Style>
    </UserControl.Styles>
    
    <StackPanel>
        <DockPanel>
            <TextBlock Text="Arrangement" DockPanel.Dock="Left" Padding="12 0 6 0" VerticalAlignment="Center"
                    Background="Transparent">
                <TextBlock.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Reset arrangement" Click="ResetArrangementButtonClick" />
                    </ContextMenu>
                </TextBlock.ContextMenu>
            </TextBlock>

            <Button x:Name="AddPartFlyoutToggleButton" IsVisible="False"
                    VerticalContentAlignment="Center" DockPanel.Dock="Right" Padding="10"
                    Cursor="Hand"
                    Flyout="{StaticResource MySharedFlyout}">
                <material:MaterialIcon Kind="PlusCircleOutline" Foreground="#888888" Margin="-4"
                                       VerticalAlignment="Center" />
            </Button>

            <ItemsControl ItemsSource="{Binding ArrangementAsRefList}" MinHeight="20" Margin="4"
                          VerticalAlignment="Center" Name="PART_ArrangementTokens">
                <ItemsControl.Styles>
                    <Style Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter DockPanel#PART_Container">
                        <Setter Property="Margin" Value="0 2 -5 2" />
                    </Style>
                    <Style
                        Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter DockPanel#PART_Container Border#PART_Content">
                        <Setter Property="Padding" Value="12 0" />
                    </Style>
                    <Style
                        Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter:nth-child(1) DockPanel#PART_Container Path#PART_Before">
                        <Setter Property="IsVisible" Value="True" />
                    </Style>
                    <Style
                        Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter:nth-child(1) DockPanel#PART_Container Border#PART_Content">
                        <Setter Property="CornerRadius" Value="0" />
                        <Setter Property="Padding" Value="12 0" />
                    </Style>
                    <Style
                        Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter:nth-last-child(1) DockPanel#PART_Container">
                        <Setter Property="Margin" Value="0 2 0 2" />
                    </Style>
                    
                    <!-- Hover Buttons visibility -->
                    <Style Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter Button.HoverInsertButton.AfterButton">
                        <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter:nth-last-child(1) Button.HoverInsertButton.AfterButton">
                        <Setter Property="IsVisible" Value="True" />
                    </Style>
                    <Style Selector="ItemsControl#PART_ArrangementTokens > ContentPresenter Button.HoverInsertButton.BeforeButton">
                        <Setter Property="IsVisible" Value="True" />
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Classes="Pill">
                            <Grid.Styles>
                                <Style Selector="Button.HoverInsertButton">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="Width" Value="20" />
                                    <Setter Property="ZIndex" Value="100" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="Button.HoverInsertButton:pointerover">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="Background" Value="Yellow" />
                                </Style>
                                <Style Selector="Button.HoverInsertButton.flyout-open">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="Background" Value="Yellow" />
                                </Style>
                            </Grid.Styles>
                            <DockPanel Name="PART_Container" Cursor="Hand" Background="Transparent">
                                <DockPanel.ContextMenu>
                                    <ContextMenu PlacementAnchor="Bottom" PlacementMode="Bottom"
                                                 PlacementTarget="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Border}}}">
                                        <MenuItem Header="Repeat" Click="OnRepeatPartClick" />
                                        <MenuItem Header="Remove" Click="OnRemovePartClick" />
                                    </ContextMenu>
                                </DockPanel.ContextMenu>

                                <Path Name="PART_Before" Data="M0,0 10,0 10,20 0,20 10,10"
                                      Fill="{Binding SongStanza.Colour}" />
                                <Border Name="PART_Content" Background="{Binding SongStanza.Colour}"
                                        BorderBrush="#aaaaaa"
                                        Margin="-1 0 -0 0">
                                    <TextBlock VerticalAlignment="Center" Foreground="Black" FontSize="12"
                                               Text="{Binding SongStanza.Name}" />
                                </Border>
                                <Path Name="PART_After" IsHitTestVisible="False" Data="M0,0 8,10 0,20" Fill="{Binding SongStanza.Colour}" />
                                <i:Interaction.Behaviors>
                                    <behaviours:StanzaDragControlBehavior />
                                </i:Interaction.Behaviors>
                            </DockPanel>
                            <Button Classes="HoverInsertButton BeforeButton"
                                    HorizontalAlignment="Left"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    DataContext="{Binding $parent[controls:SongArrangementControl].DataContext}"
                                    Flyout="{StaticResource MySharedFlyout}">
                                <material:MaterialIcon Kind="PlusCircleOutline" Foreground="#888888" Margin="-4"
                                                       VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="HoverInsertButton AfterButton"
                                    Tag="After"
                                    HorizontalAlignment="Right"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    DataContext="{Binding $parent[controls:SongArrangementControl].DataContext}"
                                    Flyout="{StaticResource MySharedFlyout}">
                                <material:MaterialIcon Kind="PlusCircleOutline" Foreground="#888888" Margin="-4"
                                                       VerticalAlignment="Center" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button IsVisible="False" Background="Transparent" BorderThickness="0" Flyout="{StaticResource MySharedFlyout}" />

        </DockPanel>

    </StackPanel>
</UserControl>