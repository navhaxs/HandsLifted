<UserControl
    Background="White"
    d:DesignHeight="650"
    d:DesignWidth="500"
    mc:Ignorable="d"
    x:Class="HandsLiftedApp.Core.Views.Editors.SongLyricBlockEditor"
    x:DataType="editor:SongEditorViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:behaviours="clr-namespace:HandsLiftedApp.Controls.Behaviours;assembly=HandsLiftedApp.Controls"
    xmlns:converters="clr-namespace:HandsLiftedApp.Controls.Converters;assembly=HandsLiftedApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editor="clr-namespace:HandsLiftedApp.Core.ViewModels.Editor"
    xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
    xmlns:material="using:Material.Icons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <editor:ExampleSongEditorViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <converters:XmlColorToBrushConverter x:Key="XmlColorToBrush" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <Border
            BorderBrush="#eee"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom"
            Margin="0,6,0,0">
            <TextBox
                AcceptsReturn="True"
                Background="Transparent"
                FontSize="13"
                Foreground="Black"
                HorizontalAlignment="Stretch"
                Margin="16,0,12,0"
                Padding="0,6,0,5"
                Text="{Binding Song.Copyright}"
                TextWrapping="Wrap"
                Watermark="Copyright"
                x:Name="CopyrightTextBox">
                <i:Interaction.Behaviors>
                    <behaviours:StanzaTextBoxBehavior />
                </i:Interaction.Behaviors>
            </TextBox>
        </Border>

        <Grid>
            <ScrollViewer>
                <StackPanel Margin="0,0,0,60" x:Name="Wrapper">
                    <TextBox
                        Background="White"
                        FontSize="30"
                        FontWeight="Bold"
                        Foreground="Black"
                        Margin="12,0,12,0"
                        Padding="0,20,0,0"
                        Text="{Binding Song.Title}"
                        TextWrapping="Wrap"
                        Watermark="Song Title">
                        <i:Interaction.Behaviors>
                            <behaviours:StanzaTextBoxBehavior />
                        </i:Interaction.Behaviors>
                    </TextBox>

                    <Button
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="0"
                        Foreground="Black"
                        HorizontalAlignment="Right"
                        Margin="0"
                        VerticalAlignment="Stretch">
                        <Button.Content>
                            <material:MaterialIcon Kind="MenuDown" />
                        </Button.Content>
                        <Button.Flyout>
                            <Flyout>
                                <DockPanel Height="120" MinWidth="200">
                                    <TextBlock DockPanel.Dock="Top">Rearrange Stanzas</TextBlock>
                                    <StackPanel DockPanel.Dock="Right">
                                        <Button Click="MoveUp_OnClick" Content="Move up" />
                                        <Button Click="MoveDown_OnClick" Content="Move down" />
                                    </StackPanel>
                                    <ListBox ItemsSource="{Binding Song.Stanzas}" x:Name="StanzaArrangementListBox">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Flyout>

                        </Button.Flyout>
                    </Button>

                    <ItemsControl ItemsSource="{Binding Song.Stanzas}" Margin="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Background="{Binding Colour}">
                                        <DockPanel>
                                            <Button
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Padding="0">
                                                <Button.Styles>
                                                    <Style Selector="Button">
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </Style>
                                                </Button.Styles>
                                                <Button.Flyout>
                                                    <Flyout>
                                                        <StackPanel>
                                                            <TextBlock>Delete this stanza?</TextBlock>
                                                            <TextBlock>This cannot be undone</TextBlock>
                                                            <Button
                                                                Click="DeleteThisPartClick"
                                                                Content="Confirm"
                                                                HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                                <material:MaterialIcon
                                                    DockPanel.Dock="Right"
                                                    Foreground="#AAA"
                                                    Height="24"
                                                    Kind="BinOutline"
                                                    Margin="8,0"
                                                    VerticalAlignment="Stretch"
                                                    Width="24" />
                                            </Button>
                                            <!--<ComboBox
                                     ItemsSource="{Binding Source={x:Static app:Globals.MainViewModel}, Path=Playlist.Designs}"
                                     SelectedItem="{Binding Design}">
                                     <ComboBox.ItemTemplate>
                                         <DataTemplate>
                                             <DockPanel>
                                                 <TextBlock Text="{Binding Name}" DockPanel.Dock="Bottom"
                                                            HorizontalAlignment="Center" Margin="0 6 0 0" />
                                                 <Viewbox Height="30">
                                                     <Grid
                                                         Height="130"
                                                         Width="130"
                                                         Background="{Binding BackgroundAvaloniaColour, Converter={StaticResource XmlColorToBrush}}">
                                                         <TextBlock Text="A"
                                                                    FontSize="80"
                                                                    Margin="20"
                                                                    FontFamily="{Binding FontFamilyAsAvalonia, FallbackValue='Arial'}"
                                                                    FontWeight="SemiBold" />
                                                     </Grid>
                                                 </Viewbox>
                                             </DockPanel>
                                         </DataTemplate>
                                     </ComboBox.ItemTemplate>
                                 </ComboBox>-->
                                            <TextBox
                                                AcceptsReturn="False"
                                                Background="Transparent"
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Foreground="Black"
                                                Padding="16,6,80,6"
                                                Text="{Binding Path=Name}"
                                                TextWrapping="Wrap"
                                                Watermark="Stanza Name">
                                                <i:Interaction.Behaviors>
                                                    <behaviours:StanzaTextBoxBehavior />
                                                </i:Interaction.Behaviors>
                                            </TextBox>
                                        </DockPanel>
                                    </Border>

                                    <!--  Lyrics Text  -->
                                    <TextBox
                                        AcceptsReturn="True"
                                        Background="Transparent"
                                        FontSize="14"
                                        Foreground="Black"
                                        LineHeight="20"
                                        Padding="16,6,16,6"
                                        Text="{Binding Path=Lyrics}"
                                        TextWrapping="Wrap"
                                        Watermark="Stanza Lyrics">
                                        <i:Interaction.Behaviors>
                                            <behaviours:StanzaTextBoxBehavior />
                                        </i:Interaction.Behaviors>
                                    </TextBox>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>


                </StackPanel>
            </ScrollViewer>

            <Button
                Background="#4d347f"
                BorderThickness="0"
                Click="Button_OnClick"
                ClickMode="Press"
                CornerRadius="6"
                Cursor="Hand"
                DockPanel.Dock="Bottom"
                FontSize="14"
                Foreground="White"
                HorizontalAlignment="Right"
                HorizontalContentAlignment="Left"
                Margin="6,0,6,8"
                Name="AddItemButton"
                Padding="12"
                VerticalAlignment="Bottom">
                <Button.Styles>
                    <Style Selector="ScrollViewer">
                        <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
                    </Style>
                    <Style Selector="MenuItem">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Padding" Value="8 6" />
                    </Style>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5C3AB6" />
                    </Style>
                    <Style Selector="Button:pressed /template/ ContentPresenter">
                        <Setter Property="BorderBrush" Value="#2c628b" />
                        <Setter Property="Background" Value="#5F5C2ED6" />
                    </Style>
                </Button.Styles>
                <Button.Effect>
                    <DropShadowEffect
                        BlurRadius="6"
                        Color="#55000000"
                        OffsetX="0"
                        OffsetY="1" />
                </Button.Effect>

                <DockPanel>
                    <material:MaterialIcon
                        DockPanel.Dock="Left"
                        Height="20"
                        Kind="Plus"
                        Width="20" />
                    <TextBlock
                        IsVisible="True"
                        Margin="8,0,8,0"
                        Text="Add Stanza" />
                </DockPanel>
            </Button>

        </Grid>

    </DockPanel>
</UserControl>