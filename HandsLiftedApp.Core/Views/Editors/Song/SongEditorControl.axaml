<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="HandsLiftedApp.Core.Views.Editors.Song.SongEditorControl"
    x:DataType="editor:SongEditorViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:common="clr-namespace:HandsLiftedApp.Common;assembly=HandsLiftedApp.Common"
    xmlns:controls="clr-namespace:HandsLiftedApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editor="clr-namespace:HandsLiftedApp.Core.ViewModels.Editor"
    xmlns:editors="clr-namespace:HandsLiftedApp.Core.Views.Editors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:slides="clr-namespace:HandsLiftedApp.Data.Slides"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>

        <Grid.Styles>
            <Style Selector="GridSplitter">
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border
                            Background="#282828"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <Border
                                Background="{TemplateBinding Background}"
                                Margin="-6,0,0,0"
                                MaxHeight="60"
                                Width="1" />
                        </Border>
                    </ControlTemplate>
                </Setter>
            </Style>
        </Grid.Styles>

        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="380" Width="*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <TabControl
            Margin="0,0,0,0"
            Name="TabControl"
            Padding="0"
            TabStripPlacement="Bottom">

            <TabControl.Styles>
                <Style Selector="TabItem:selected">
                    <Setter Property="Foreground" Value="White" />
                </Style>
                <Style Selector="TabItem:pointerover">
                    <Setter Property="Foreground" Value="White" />
                </Style>
                <Style Selector="TabItem">
                    <Setter Property="Margin" Value="4 0 0 0" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="CornerRadius" Value="2 0 0 2" />
                    <Setter Property="MinWidth" Value="60" />
                </Style>
                <Style Selector="TabControl /template/ ContentPresenter#PART_SelectedContentHost" />
            </TabControl.Styles>

            <TabItem Header="Stanzas">
                <ScrollViewer>
                    <editors:SongLyricBlockEditor />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Text">
                <editors:SongLyricFreeTextEditor />
            </TabItem>

            <TabItem Header="Design">
                <StackPanel Margin="12">
                    <StackPanel Margin="12">
                        <TextBlock Margin="0,0,0,6" Text="Slide Theme" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding Playlist.Designs}"
                            SelectedItem="{Binding SelectedSlideTheme}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock
                            FontSize="11"
                            IsVisible="{Binding SelectedSlideTheme, Converter={x:Static ObjectConverters.IsNull}}"
                            Margin="0,6,0,0"
                            Opacity="0.6"
                            Text="(None selected — uses default theme)" />
                    </StackPanel>

                    <StackPanel>
                        <DockPanel Margin="8">
                            <Button
                                Click="ClearMotionBackground_OnClick"
                                Content="Clear"
                                DockPanel.Dock="Right"
                                Margin="4,0,0,0" />
                            <Button
                                Click="BrowseMotionBackground_OnClick"
                                Content="..."
                                DockPanel.Dock="Right"
                                Margin="4,0,0,0" />
                            <TextBox
                                IsReadOnly="True"
                                Text="{Binding Song.MotionBackgroundVideoPath}"
                                Watermark="No video file selected" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </TabItem>

        </TabControl>

        <GridSplitter Grid.Column="1" />

        <Border Grid.Column="2">
            <Grid>
                <DockPanel Margin="16,4,16,16">
                    <controls:SongArrangementControl
                        DataContext="{Binding Song}"
                        DockPanel.Dock="Top"
                        Margin="0,8" />
                    <Border
                        Background="#AAAAAA"
                        BoxShadow="inset 0 0 2 #c1c1c1"
                        CornerRadius="6"
                        HorizontalAlignment="Stretch"
                        Padding="6"
                        VerticalAlignment="Stretch">
                        <ScrollViewer>
                            <ListBox
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding Song.Slides}"
                                Name="List"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.Styles>
                                    <StyleInclude Source="avares://HandsLiftedApp.Controls/ListBoxItem.axaml" />
                                </ListBox.Styles>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel
                                            IsHitTestVisible="False"
                                            ItemHeight="160"
                                            ItemWidth="240" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.DataTemplates>
                                    <common:MyTemplateSelector>
                                        <DataTemplate x:DataType="slides:SongTitleSlideInstance" x:Key="SongTitleSlideInstance">
                                            <Image
                                                RenderOptions.BitmapInterpolationMode="LowQuality"
                                                Source="{Binding Thumbnail}"
                                                Stretch="Uniform" />
                                        </DataTemplate>
                                        <DataTemplate x:DataType="slides:SongSlideInstance" x:Key="SongSlideInstance">
                                            <Image
                                                RenderOptions.BitmapInterpolationMode="LowQuality"
                                                Source="{Binding Thumbnail}"
                                                Stretch="Uniform" />
                                        </DataTemplate>
                                        <DataTemplate x:Key="Fallback">
                                            <TextBlock
                                                Background="Green"
                                                FontSize="80"
                                                TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </common:MyTemplateSelector>
                                </ListBox.DataTemplates>
                            </ListBox>
                        </ScrollViewer>
                    </Border>
                </DockPanel>

                <!-- <Grid Background="#1c1c1c"> -->
                <!--     <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"> -->
                <!--         <TextBlock HorizontalAlignment="Center">import from file</TextBlock> -->
                <!--         <TextBlock  HorizontalAlignment="Center">import from songselect</TextBlock> -->
                <!--     </StackPanel> -->
                <!-- </Grid> -->

                <Border IsVisible="{Binding Song.IsEmpty}">
                    <DockPanel Background="#282828">
                        <avalonia:MaterialIcon
                            Foreground="White"
                            Height="40"
                            HorizontalAlignment="Left"
                            Kind="ArrowLeft"
                            Margin="20"
                            Width="40" />
                        <StackPanel Margin="0,20,40,20" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="24"
                                Foreground="White"
                                TextWrapping="Wrap">
                                <TextBlock.Styles>
                                    <Style Selector="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </Style>
                                    <Style Selector="Button &gt; TextBlock &gt; Span">
                                        <Setter Property="Foreground" Value="#2ECAFF" />
                                    </Style>
                                    <Style Selector="Button:pointerover &gt; TextBlock &gt; Span">
                                        <Setter Property="Foreground" Value="#72DBFF" />
                                    </Style>
                                </TextBlock.Styles>
                                <avalonia:MaterialIcon
                                    Height="64"
                                    HorizontalAlignment="Left"
                                    Kind="MusicNote"
                                    Margin="-4,-4"
                                    Width="64" />
                                <LineBreak />
                                <LineBreak />
                                Create slides from lyrics<LineBreak />
                                <LineBreak />
                                <Button Click="ImportFromOnlineButton_OnClick" Cursor="Hand">

                                    <TextBlock>
                                        <Span TextDecorations="Underline">
                                            import from songselect
                                        </Span>
                                        <avalonia:MaterialIcon
                                            Foreground="#2ECAFF"
                                            Height="18"
                                            HorizontalAlignment="Left"
                                            Kind="OpenInNew"
                                            Margin="-4"
                                            Width="18" />
                                    </TextBlock>
                                </Button>

                                <LineBreak />
                                <LineBreak />

                                <Button Click="ImportFromFileButton_OnClick" Cursor="Hand">
                                    <TextBlock>
                                        <Span TextDecorations="Underline">
                                            import from file
                                        </Span>
                                        <avalonia:MaterialIcon
                                            Foreground="#2ECAFF"
                                            Height="18"
                                            HorizontalAlignment="Left"
                                            Kind="FolderOpen"
                                            Margin="-4"
                                            Width="18" />
                                    </TextBlock>
                                </Button>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>