<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="400"
        Height="160"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        ShowInTaskbar="False"
        CanResize="False"
        x:Class="HandsLiftedApp.Core.Views.RestoreAutosaveConfirmationWindow"
        Icon="/Assets/app.ico"
        Title="Restore Autosave">
    <Border CornerRadius="8"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1">
        <DockPanel Margin="15">
            <StackPanel Margin="0 10 0 0" DockPanel.Dock="Bottom"
                        Orientation="Horizontal" HorizontalAlignment="Right" Spacing="5">
                <Button Content="Restore" IsDefault="True" Click="OnConfirmRestore" />
                <Button Content="Ignore" Click="OnIgnore" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Autosave Found"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Margin="10 10 0 0"
                           FontSize="14" />
                <TextBlock Text="A newer autosave of this playlist was found. Would you like to restore it?"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="10 10 10 0"
                           FontSize="14" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>