<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:slides1="clr-namespace:HandsLiftedApp.Data.Slides"
             xmlns:designer="clr-namespace:HandsLiftedApp.Core.Views.Designer"
             xmlns:skia="clr-namespace:HandsLiftedApp.Core.Render.Skia"
             mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
             x:DataType="slides1:SongSlideInstance"
             x:Class="HandsLiftedApp.Core.Views.Designer.SongSlideView">

    <Design.DataContext>
        <designer:DesignModeSongSlideInstance />
    </Design.DataContext>

    <Grid>
        <skia:SlideCanvas x:Name="SlideCanvas" />
        <!-- Editing overlays go here in future tasks (resize handles, text boxes) -->
    </Grid>
</UserControl>
