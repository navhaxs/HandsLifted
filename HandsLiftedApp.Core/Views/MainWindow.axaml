<Window
    Background="{DynamicResource SurfaceBrush}"
    ExtendClientAreaChromeHints="SystemChrome,PreferSystemChrome"
    ExtendClientAreaTitleBarHeightHint="90"
    ExtendClientAreaToDecorationsHint="True"
    Icon="/Assets/app.ico"
    MinHeight="500"
    MinWidth="1000"
    Opened="TopLevel_OnOpened"
    ShowInTaskbar="True"
    Title="VisionScreens"
    WindowStartupLocation="CenterScreen"
    WindowState="Normal"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="HandsLiftedApp.Core.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:HandsLiftedApp.Core.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="RootBorder">
        <Grid>
            <views:MainView />
            <Rectangle
                Fill="#80000000"
                IsVisible="False"
                x:Name="Shade" />
        </Grid>
    </Border>

    <!-- <Window.ContextMenu> -->
    <!--     <ContextMenu> -->
    <!--         <TextBlock Text="Debug" Foreground="Red" /> -->
    <!--     </ContextMenu> -->
    <!-- </Window.ContextMenu> -->

</Window>