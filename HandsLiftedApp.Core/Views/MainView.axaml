<UserControl
    d:DesignHeight="550"
    d:DesignWidth="1220"
    mc:Ignorable="d"
    x:Class="HandsLiftedApp.Core.Views.MainView"
    x:DataType="vm:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:app="clr-namespace:HandsLiftedApp.Core"
    xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:HandsLiftedApp.Controls;assembly=HandsLiftedApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:designer="clr-namespace:HandsLiftedApp.Views.Designer"
    xmlns:library="clr-namespace:HandsLiftedApp.Views.Library"
    xmlns:material="using:Material.Icons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:navigation="clr-namespace:HandsLiftedApp.Core.Controls.Navigation"
    xmlns:views="clr-namespace:HandsLiftedApp.Core.Views"
    xmlns:vm="clr-namespace:HandsLiftedApp.Core.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ControlBackgroundBrush">#ffffff</SolidColorBrush>
                    <SolidColorBrush x:Key="BottomBackgroundBrush">#257E78A8</SolidColorBrush>
                    <SolidColorBrush x:Key="SlideNavigationButtonBackgroundBrush">#f5f5f5</SolidColorBrush>
                    <SolidColorBrush x:Key="ForegroundBrush">Black</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentBackgroundBrush">#4D347F</SolidColorBrush>
                    <SolidColorBrush x:Key="GridSplitterBrush">#9b97ad</SolidColorBrush>
                    <SolidColorBrush x:Key="PlaylistTitleBrush">#2f2f30</SolidColorBrush>
                    <SolidColorBrush x:Key="HoverBrush">#C11F576F</SolidColorBrush>
                    <SolidColorBrush x:Key="ActiveToggleButtonBackgroundBrush">#D8CEEC</SolidColorBrush>
                    <SolidColorBrush Color="Red" x:Key="CaptionButtonBackground" />
                    <SolidColorBrush Color="#ADC5D3" x:Key="LibraryAndDesignerBackground" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush Color="Red" x:Key="CaptionButtonBackground" />
                    <SolidColorBrush x:Key="ControlBackgroundBrush">#121212</SolidColorBrush>
                    <SolidColorBrush x:Key="BottomBackgroundBrush">#1e1e1e</SolidColorBrush>
                    <SolidColorBrush x:Key="SlideNavigationButtonBackgroundBrush">#444</SolidColorBrush>
                    <SolidColorBrush x:Key="ForegroundBrush">White</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentBackgroundBrush">#377D61C6</SolidColorBrush>
                    <SolidColorBrush x:Key="GridSplitterBrush">Black</SolidColorBrush>
                    <SolidColorBrush x:Key="PlaylistTitleBrush">White</SolidColorBrush>
                    <SolidColorBrush x:Key="HoverBrush">#C11F576F</SolidColorBrush>
                    <SolidColorBrush x:Key="ActiveToggleButtonBackgroundBrush">#3a3449</SolidColorBrush>
                    <SolidColorBrush Color="#3a576f" x:Key="LibraryAndDesignerBackground" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="DockedLibraryWrapper">
        <Grid.Styles>
            <Style Selector="RowDefinition.isCollapsed">
                <Style.Setters>
                    <Setter Property="Height" Value="0" />
                </Style.Setters>
            </Style>
        </Grid.Styles>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="1" />
            <RowDefinition Height="0" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!--  root grid: content and right panel  -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition
                    MaxWidth="800"
                    MinWidth="200"
                    Width="0.24*" />
            </Grid.ColumnDefinitions>

            <!--  inner grid: left panel and content  -->
            <DockPanel>

                <DockPanel
                    DockPanel.Dock="Top"
                    Height="62"
                    Margin="0,8,0,0">

                    <DockPanel>
                        <Button
                            Background="Transparent"
                            BorderThickness="0"
                            ClickMode="Press"
                            CornerRadius="0"
                            DockPanel.Dock="Left"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            HotKey="Alt+M"
                            Margin="8,0,0,0"
                            Name="AppMenuButton"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Stretch">

                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                    <MenuItem Click="StartScreenButton_Clicked" Header="Start Screen">
                                        <MenuItem.Icon>
                                            <avalonia:MaterialIcon Foreground="#888888" Kind="Home" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator />

                                    <MenuItem Click="NewFileButton_Clicked" Header="New">
                                        <MenuItem.Icon>
                                            <avalonia:MaterialIcon Foreground="#888888" Kind="Shimmer" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem
                                        Click="OpenFileButton_Clicked"
                                        Header="Load"
                                        HotKey="Ctrl+O">
                                        <MenuItem.Icon>
                                            <material:MaterialIcon Foreground="#888888" Kind="FolderOpen" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem
                                        Click="SaveFileButton_Clicked"
                                        Header="Save"
                                        HotKey="Ctrl+S"
                                        IsEnabled="{Binding Playlist.PlaylistFilePath, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <MenuItem.Icon>
                                            <material:MaterialIcon Foreground="#888888" Kind="ContentSave" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem
                                        Click="SaveFileAsButton_Clicked"
                                        Header="Save As"
                                        HotKey="Ctrl+Shift+S">
                                        <MenuItem.Icon>
                                            <material:MaterialIcon Foreground="#888888" Kind="ContentSaveAll" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator />

                                    <MenuItem Click="PlaylistInfoButton_Clicked" Header="Playlist Info">
                                        <MenuItem.Icon>
                                            <material:MaterialIcon Foreground="#888888" Kind="InfoCircle" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator />

                                    <MenuItem Click="Slide_OnClick" Header="Slide Designer">
                                        <MenuItem.Icon>
                                            <material:MaterialIcon Foreground="#888888" Kind="Paintbrush" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator />

                                    <MenuItem Click="Setup_OnClick" Header="Setup">
                                        <MenuItem.Icon>
                                            <material:MaterialIcon Foreground="#888888" Kind="Cog" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator />

                                    <MenuItem Click="About_OnClick" Header="About">
                                        <MenuItem.Icon>
                                            <material:MaterialIcon Foreground="#888888" Kind="HelpCircle" />
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Click="CloseWindow" Header="Exit" />

                                </MenuFlyout>
                            </Button.Flyout>

                            <Button.Styles>
                                <Style Selector="Button:flyout-open Border.AppButtonBorder">
                                    <Setter Property="Background" Value="#5c3ab6" />
                                </Style>
                                <Style Selector="Button:pointerover Border.AppButtonBorder">
                                    <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                </Style>
                                <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#9a93cd" />
                                    <!--<Setter Property="Background" Value="Transparent" />-->
                                </Style>
                                <Style Selector="Button:checked /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="Button:checked TextBlock">
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                                <Style Selector="Button:pressed Border.AppButtonBorder">
                                    <Setter Property="Background" Value="#9a93cd" />
                                </Style>
                                <Style Selector="Button:checked Border.AppButtonBorder">
                                    <Setter Property="Background" Value="#5E3593" />
                                </Style>
                                <Style Selector="Button:checked material|MaterialIcon">
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </Button.Styles>

                            <Border
                                Classes="AppButtonBorder"
                                CornerRadius="6"
                                Padding="12">
                                <material:MaterialIcon
                                    Height="20"
                                    Kind="DotsHorizontal"
                                    Margin="6,0"
                                    Width="20" />
                            </Border>
                        </Button>
                        <Grid IsHitTestVisible="False" />
                    </DockPanel>

                    <Ellipse
                        DockPanel.Dock="Left"
                        Fill="White"
                        Height="6"
                        HorizontalAlignment="Left"
                        IsHitTestVisible="False"
                        IsVisible="{Binding Playlist.IsDirty}"
                        VerticalAlignment="Center"
                        Width="6" />

                    <controls:TextBoxToggleButton
                        DockPanel.Dock="Top"
                        FontSize="22"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,0"
                        Padding="7"
                        Text="{Binding Playlist.Title, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        Watermark="Untitled Playlist" />

                </DockPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="6" Width="260" />
                        <ColumnDefinition Width="0" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel>
                        <navigation:ItemOrderListView
                            DataContext="{Binding Playlist}"
                            DockPanel.Dock="Left"
                            Margin="0,6,0,0" />
                    </DockPanel>

                    <GridSplitter
                        BorderBrush="Transparent"
                        BorderThickness="3,0"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Margin="-3,0"
                        ZIndex="999" />

                    <!--  centre panel  -->
                    <!--  TODO write a custom Converter to BoxShadow from {DynamicResource SurfaceBrush}  -->
                    <Border
                        Background="{DynamicResource DarkSurfaceBrush}"
                        BorderBrush="{DynamicResource GridSplitterBrush}"
                        BorderThickness="1,1,0,1"
                        CornerRadius="6,0,0,6"
                        Grid.Column="2"
                        Margin="0,0,-1,6">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Bottom" HorizontalAlignment="Right">
                                <DockPanel.Styles>
                                    <Style Selector="Button">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </DockPanel.Styles>
                                <Button Click="ZoomOutButton_OnClick" Padding="6,0,0,0">
                                    <avalonia:MaterialIcon Foreground="#808080" Kind="Minus" />
                                </Button>
                                <Button
                                    Click="ZoomInButton_OnClick"
                                    DockPanel.Dock="Right"
                                    Padding="0,0,6,0">
                                    <avalonia:MaterialIcon Foreground="#808080" Kind="Plus" />
                                </Button>
                                <Slider
                                    IsSnapToTickEnabled="True"
                                    Maximum="150"
                                    Minimum="50"
                                    Name="BackgroundSlider"
                                    TickFrequency="0.1"
                                    Value="{Binding Source={x:Static app:Globals.Instance}, Path=AppPreferences.SlideThumbnailSizeMultiplier}"
                                    Width="100" />
                            </DockPanel>
                            <!--    -->
                            <!--  <Border  -->
                            <!--  Height="50"  -->
                            <!--  Padding="10,5,10,5"  -->
                            <!--  BorderBrush="{DynamicResource NavigationBarBorderBrush}"  -->
                            <!--  BorderThickness="0 1 0 0"  -->
                            <!--  CornerRadius="0 0 0 6"  -->
                            <!--  Background="{DynamicResource NavigationBarBrush}"  -->
                            <!--  DockPanel.Dock="Bottom">  -->
                            <!--     <Grid MaxWidth="1200"> -->
                            <!--         <Grid.Styles> -->
                            <!--             <Style Selector="Button"> -->
                            <!--  <Setter Property="BorderThickness"  -->
                            <!--  Value="0" />  -->
                            <!--  <Setter Property="Background"  -->
                            <!--  Value="{DynamicResource ButtonBackgroundBrush}" />  -->
                            <!--  <Setter Property="Foreground"  -->
                            <!--  Value="{DynamicResource TextBrush}" />  -->
                            <!--  <Setter Property="CornerRadius"  -->
                            <!--  Value="99" />  -->
                            <!--                 <Setter Property="HorizontalAlignment" Value="Stretch" /> -->
                            <!--                 <Setter Property="HorizontalContentAlignment" Value="Center" /> -->
                            <!--                 <Setter Property="Margin" Value="6 2" /> -->
                            <!--                 <Setter Property="FontSize" Value="14" /> -->
                            <!--             </Style> -->
                            <!--             <Style Selector="Button:pointerover /template/ ContentPresenter"> -->
                            <!--                 <Setter Property="Background" Value="#b7a6e7" /> -->
                            <!--             </Style> -->
                            <!--             <Style Selector="Button:pressed /template/ ContentPresenter"> -->
                            <!--                 <Setter Property="BorderBrush" Value="#2c628b" /> -->
                            <!--                 <Setter Property="Background" Value="#9072EA" /> -->
                            <!--             </Style> -->
                            <!--         </Grid.Styles> -->
                            <!--         <Grid.ColumnDefinitions> -->
                            <!--             <ColumnDefinition Width="*" /> -->
                            <!--             <ColumnDefinition Width="*" /> -->
                            <!--             <ColumnDefinition Width="*" /> -->
                            <!--         </Grid.ColumnDefinitions> -->
                            <!--  <Button  -->
                            <!--  Padding="6,0"  -->
                            <!--  HorizontalContentAlignment="Stretch"  -->
                            <!--  VerticalContentAlignment="Stretch"  -->
                            <!--  Command="{Binding OnPrevSlideClickCommand}"  -->
                            <!--  IsTabStop="False">  -->
                            <!--             <Grid Margin="6,0"> -->
                            <!--                 <material:MaterialIcon HorizontalAlignment="Left" Kind="ArrowLeft" /> -->
                            <!--  <TextBlock  -->
                            <!--  VerticalAlignment="Center"  -->
                            <!--  Text="Previous"  -->
                            <!--  TextAlignment="Center" />  -->
                            <!--             </Grid> -->
                            <!--         </Button> -->
                            <!--  <Button  -->
                            <!--  Grid.Column="1"  -->
                            <!--  HorizontalAlignment="Stretch"  -->
                            <!--  VerticalAlignment="Stretch"  -->
                            <!--  Background="Transparent"  -->
                            <!--  BorderThickness="0"  -->
                            <!--  Click="OnScrollToItemClick"  -->
                            <!--  FontSize="16" />  -->
                            <!--  ~1~ <TextBlock @1@  -->
                            <!--  ~1~     Grid.Column="1" @1@  -->
                            <!--  ~1~     HorizontalAlignment="Center" @1@  -->
                            <!--  ~1~     VerticalAlignment="Center" @1@  -->
                            <!--  ~1~     FontSize="15" @1@  -->
                            <!--  ~1~     Text="{Binding Playlist.State.SelectedSlideItemDisplayText}" /> @1@  -->
                            <!--  <Button  -->
                            <!--  Grid.Column="2"  -->
                            <!--  HorizontalAlignment="Stretch"  -->
                            <!--  HorizontalContentAlignment="Stretch"  -->
                            <!--  Command="{Binding OnNextSlideClickCommand}"  -->
                            <!--  IsTabStop="False">  -->
                            <!--             <Grid Margin="6,0"> -->
                            <!--                 <material:MaterialIcon HorizontalAlignment="Right" Kind="ArrowRight" /> -->
                            <!--  <TextBlock  -->
                            <!--  VerticalAlignment="Center"  -->
                            <!--  Text="Next"  -->
                            <!--  TextAlignment="Center" />  -->
                            <!--             </Grid> -->
                            <!--         </Button> -->
                            <!--     </Grid> -->
                            <!-- </Border> -->

                            <Border
                                Background="{DynamicResource BackgroundBrush}"
                                CornerRadius="6,0,0,0"
                                HorizontalAlignment="Stretch">

                                <views:PlaylistSlidesView DataContext="{Binding Playlist}" />
                                <!-- <ScrollViewer> -->
                                <!--     <controls1:ItemSlidesView DataContext="{Binding Playlist.SelectedItem}" /> -->
                                <!-- </ScrollViewer> -->
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </DockPanel>

            <GridSplitter
                Background="{DynamicResource GridSplitterBrush}"
                BorderBrush="Transparent"
                BorderThickness="4,0"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Margin="-3,0,-3,0"
                ZIndex="9999" />

            <!-- <views:ItemContentView Grid.Column="4" DataContext="{Binding Playlist.SelectedItem}" /> -->

            <Border
                BorderBrush="{DynamicResource GridSplitterBrush}"
                BorderThickness="1,0,0,0"
                Grid.Column="2">
                <views:LivePane VerticalAlignment="Stretch" />
            </Border>

        </Grid>
        <!--  end root grid  -->

        <GridSplitter
            Background="Transparent"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Margin="0,0,0,0"
            ZIndex="9999" />

        <Border
            Background="{DynamicResource LibraryAndDesignerBackground}"
            CornerRadius="6,6,6,0"
            DockPanel.Dock="Bottom"
            Grid.Row="2"
            Margin="6,0"
            Padding="10"
            VerticalAlignment="Stretch">
            <Carousel BorderThickness="0" SelectedIndex="{Binding BottomLeftPanelSelectedTabIndex}">
                <library:LibraryPaneView />
                <designer:DesignerView />
            </Carousel>
        </Border>

        <!--  Docked toggle buttons  -->
        <Border Background="{DynamicResource DarkSurfaceBrush}" Grid.Row="3">

            <DockPanel>
                <Button
                    Background="Transparent"
                    BorderThickness="0"
                    Click="Debug_OnClick"
                    DockPanel.Dock="Right"
                    FontWeight="Bold"
                    Foreground="Red"
                    Margin="6"
                    VerticalAlignment="Center">
                    Pre-release software
                </Button>
                <Grid />

                <!-- <Grid Width="{Binding #RightPanel.Bounds.Width}" DockPanel.Dock="Right" /> -->

                <StackPanel Orientation="Horizontal">
                    <StackPanel.Styles>
                        <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Style>
                        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource LibraryAndDesignerBackground}" />
                            <Setter Property="CornerRadius" Value="0" />
                        </Style>
                        <Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Style>
                        <Style Selector="ToggleButton:pressed /template/ ContentPresenter">
                            <Setter Property="BorderBrush" Value="#337CB3" />
                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Style>
                        <Style Selector="ToggleButton TextBlock">
                            <Setter Property="Margin" Value="6 0 0 0" />
                        </Style>
                    </StackPanel.Styles>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="MenuItem"
                        DockPanel.Dock="Bottom"
                        Margin="6,0,6,0"
                        Name="LibraryToggleButton"
                        Padding="10,10,14,8">

                        <DockPanel>
                            <avalonia:MaterialIcon
                                DockPanel.Dock="Left"
                                Foreground="{DynamicResource ForegroundBrush}"
                                Kind="Bookshelf" />
                            <TextBlock Text="Library" VerticalAlignment="Center" />
                        </DockPanel>
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="MenuItem"
                        DockPanel.Dock="Bottom"
                        Name="DesignerToggleButton"
                        Padding="10,10,14,8">
                        <DockPanel>
                            <avalonia:MaterialIcon
                                DockPanel.Dock="Left"
                                Foreground="{DynamicResource ForegroundBrush}"
                                Kind="Paintbrush" />
                            <TextBlock Text="Designer" VerticalAlignment="Center" />
                        </DockPanel>
                    </ToggleButton>

                </StackPanel>
            </DockPanel>

        </Border>
        <!--  end bottom dock  -->

    </Grid>

</UserControl>